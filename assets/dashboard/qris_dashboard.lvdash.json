{
  "datasets": [
    {
      "name": "ds_qris_kpis_30d",
      "displayName": "QRIS KPIs \u2014 last 30 days",
      "queryLines": [
        "SELECT",
        "  SUM(amount_idr) AS volume_idr,",
        "  COUNT(*) AS txn_count,",
        "  COUNT(DISTINCT customer_id) AS active_customers,",
        "  COUNT(DISTINCT merchant_id) AS active_merchants,",
        "  AVG(amount_idr) AS avg_ticket_idr",
        "FROM dante_azure_sea.qris_digital_banking_demo.qris_transactions",
        "WHERE status = 'SUCCESS' AND txn_date >= date_sub(current_date(), 30)"
      ]
    },
    {
      "name": "ds_daily_volume",
      "displayName": "Daily QRIS volume",
      "queryLines": [
        "SELECT txn_date,",
        "       SUM(amount_idr) AS volume_idr,",
        "       COUNT(*) AS txn_count",
        "FROM dante_azure_sea.qris_digital_banking_demo.qris_transactions",
        "WHERE status = 'SUCCESS' AND txn_date >= date_sub(current_date(), 30)",
        "GROUP BY txn_date",
        "ORDER BY txn_date"
      ]
    },
    {
      "name": "ds_city_volume",
      "displayName": "QRIS volume by city",
      "queryLines": [
        "SELECT m.city,",
        "       SUM(q.amount_idr) AS volume_idr,",
        "       COUNT(*) AS txn_count,",
        "       COUNT(DISTINCT q.customer_id) AS unique_customers",
        "FROM dante_azure_sea.qris_digital_banking_demo.qris_transactions q",
        "JOIN dante_azure_sea.qris_digital_banking_demo.merchants m USING (merchant_id)",
        "WHERE q.status = 'SUCCESS' AND q.txn_date >= date_sub(current_date(), 30)",
        "GROUP BY m.city",
        "ORDER BY volume_idr DESC",
        "LIMIT 12"
      ]
    },
    {
      "name": "ds_top_merchants",
      "displayName": "Top 15 QRIS merchants",
      "queryLines": [
        "SELECT m.merchant_id,",
        "       m.merchant_name,",
        "       m.merchant_tier,",
        "       m.mcc_description,",
        "       m.city,",
        "       SUM(dm.qris_amount_idr) AS volume_idr,",
        "       SUM(dm.qris_txn_count)  AS txn_count",
        "FROM dante_azure_sea.qris_digital_banking_demo.daily_merchant_metrics dm",
        "JOIN dante_azure_sea.qris_digital_banking_demo.merchants m USING (merchant_id)",
        "WHERE dm.date >= date_sub(current_date(), 30)",
        "GROUP BY m.merchant_id, m.merchant_name, m.merchant_tier, m.mcc_description, m.city",
        "ORDER BY volume_idr DESC",
        "LIMIT 15"
      ]
    },
    {
      "name": "ds_segment_adoption",
      "displayName": "QRIS adoption by segment",
      "queryLines": [
        "WITH base AS (",
        "  SELECT c.segment,",
        "         COUNT(DISTINCT c.customer_id) AS total_customers,",
        "         COUNT(DISTINCT CASE WHEN c.digital_active THEN c.customer_id END) AS digital_customers,",
        "         COUNT(DISTINCT q.customer_id) AS qris_active",
        "  FROM dante_azure_sea.qris_digital_banking_demo.customers c",
        "  LEFT JOIN dante_azure_sea.qris_digital_banking_demo.qris_transactions q",
        "    ON q.customer_id = c.customer_id",
        "   AND q.status = 'SUCCESS'",
        "   AND q.txn_date >= date_sub(current_date(), 30)",
        "  GROUP BY c.segment",
        ")",
        "SELECT segment,",
        "       total_customers,",
        "       digital_customers,",
        "       qris_active,",
        "       ROUND(100.0 * qris_active / total_customers, 1) AS qris_active_pct",
        "FROM base",
        "ORDER BY total_customers DESC"
      ]
    },
    {
      "name": "ds_tier_volume",
      "displayName": "QRIS by merchant tier",
      "queryLines": [
        "SELECT m.merchant_tier,",
        "       SUM(q.amount_idr) AS volume_idr,",
        "       COUNT(*) AS txn_count,",
        "       AVG(q.amount_idr) AS avg_ticket_idr",
        "FROM dante_azure_sea.qris_digital_banking_demo.qris_transactions q",
        "JOIN dante_azure_sea.qris_digital_banking_demo.merchants m USING (merchant_id)",
        "WHERE q.status = 'SUCCESS' AND q.txn_date >= date_sub(current_date(), 30)",
        "GROUP BY m.merchant_tier",
        "ORDER BY CASE m.merchant_tier WHEN 'UMI' THEN 1 WHEN 'UKE' THEN 2 WHEN 'UMK' THEN 3 WHEN 'UBE' THEN 4 END"
      ]
    },
    {
      "name": "ds_mcc_volume",
      "displayName": "QRIS by MCC category",
      "queryLines": [
        "SELECT m.mcc_description,",
        "       SUM(q.amount_idr) AS volume_idr,",
        "       COUNT(*) AS txn_count",
        "FROM dante_azure_sea.qris_digital_banking_demo.qris_transactions q",
        "JOIN dante_azure_sea.qris_digital_banking_demo.merchants m USING (merchant_id)",
        "WHERE q.status = 'SUCCESS' AND q.txn_date >= date_sub(current_date(), 30)",
        "GROUP BY m.mcc_description",
        "ORDER BY volume_idr DESC"
      ]
    },
    {
      "name": "ds_qris_vs_bifast",
      "displayName": "QRIS vs BI-Fast volume",
      "queryLines": [
        "SELECT 'QRIS' AS rail,",
        "       SUM(amount_idr) AS volume_idr,",
        "       COUNT(*) AS txn_count",
        "FROM dante_azure_sea.qris_digital_banking_demo.qris_transactions",
        "WHERE status = 'SUCCESS' AND txn_date >= date_sub(current_date(), 30)",
        "UNION ALL",
        "SELECT 'BI-Fast' AS rail,",
        "       SUM(amount_idr) AS volume_idr,",
        "       COUNT(*) AS txn_count",
        "FROM dante_azure_sea.qris_digital_banking_demo.bifast_transfers",
        "WHERE status = 'SUCCESS' AND transfer_date >= date_sub(current_date(), 30)"
      ]
    },
    {
      "name": "ds_dau_trend",
      "displayName": "Daily Active Mobile Users",
      "queryLines": [
        "SELECT session_date,",
        "       COUNT(DISTINCT customer_id) AS dau,",
        "       COUNT(*) AS sessions",
        "FROM dante_azure_sea.qris_digital_banking_demo.mobile_sessions",
        "WHERE session_date >= date_sub(current_date(), 30)",
        "GROUP BY session_date",
        "ORDER BY session_date"
      ]
    }
  ],
